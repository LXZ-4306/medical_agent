# DeepSeek API配置（兼容OpenAI格式）
OPENAI_API_KEY=sk-your-api-key
OPENAI_BASE_URL=https://api.deepseek.com/v1
# 如果使用DeepSeek的Azure部署，则使用：
# OPENAI_BASE_URL=https://your-deepseek-azure-endpoint.openai.azure.com/

# Neo4j图数据库配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=12345678

# 应用配置
LOG_LEVEL=INFO
MAX_RETRIES=3
TEMPERATURE=0.3

# DeepSeek特定配置（可选）
DEEPSEEK_MODEL=deepseek-chat # 或 deepseek-coder
DEEPSEEK_MAX_TOKENS=4096